[Unit]
Description=Embedding Server for technical_ai (all-MiniLM-L12-v2)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/technical_ai/embedding-server
ExecStart=/var/www/technical_ai/embedding-server/venv/bin/gunicorn -w 2 -b 127.0.0.1:9500 server:app
Restart=always
RestartSec=5
Environment=EMBEDDING_MODEL=all-MiniLM-L12-v2

[Install]
WantedBy=multi-user.target
